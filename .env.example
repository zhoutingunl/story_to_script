# 复制为 .env 后按需修改；.env 不会被提交（见 .gitignore）。

# AI 后端：hermes（走 Hermes 平台，需公司内网/VPN） | offline（回放本地 fixture，无需网络）
STORY2SCRIPT_AI_BACKEND=hermes

# Hermes WebUI 地址（公司内网）
HERMES_BASE=http://10.210.32.30:8787

# 生成用模型：MiniMax-M3（默认最稳） | glm-5.1 | kimi-k2.5
STORY2SCRIPT_MODEL=MiniMax-M3

# 单次 AI 调用总时长预算（秒）
STORY2SCRIPT_AI_TIMEOUT=300

# SQLite 数据库路径
STORY2SCRIPT_DB=story2script.db

# Flask
FLASK_SECRET=dev-only-change-me
